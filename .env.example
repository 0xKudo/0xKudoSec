ANTHROPIC_API_KEY=sk-ant-your-key-here
ALLOWED_ORIGIN=http://localhost:5173
PORT=4000
NODE_ENV=development
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_AUDIENCE=https://tools.laynekudo.com/api
AUTH0_MGMT_CLIENT_ID=     # M2M app client ID — from Auth0 dashboard > Applications > 0xKudo API
AUTH0_MGMT_CLIENT_SECRET= # M2M app client secret — keep server-side only
AUTH0_TENANT_DOMAIN=      # your-tenant.us.auth0.com — used for Auth0 Management API audience URL
DB_ENCRYPTION_KEY=     # 32-byte hex key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/cybertools
INGEST_AUTH_DB_URL=    # separate DB connection string for auth/user data — falls back to DATABASE_URL if unset
OPS_DB_URL=            # separate DB connection string for ops/SIEM data — falls back to DATABASE_URL if unset
DATABASE_CA_CERT=      # path to CA certificate file for SSL DB connections in production
INGEST_API_KEY=        # generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_LOG_RETENTION_DAYS=365   # PCI DSS 10.7 minimum is 365 days — do not lower below 365 in production

# OSINT Tool API Keys
SHODAN_API_KEY=           # https://account.shodan.io
VIRUSTOTAL_API_KEY=       # https://www.virustotal.com/gui/join-us
HUNTER_API_KEY=           # https://hunter.io
IPINFO_TOKEN=             # https://ipinfo.io/signup
# WHOIS — no key needed, uses public whoisjsonapi.com endpoint

# Threat Intelligence Tool API Keys
ABUSEIPDB_API_KEY=        # https://www.abuseipdb.com/register
ABUSECH_API_KEY=          # https://auth.abuse.ch — covers ThreatFox and MalwareBazaar
